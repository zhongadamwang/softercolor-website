Options -Indexes
RewriteEngine On

# ── HTTPS redirect ──────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── www redirect (non-www → www) ────────────────────────────
RewriteCond %{HTTP_HOST} !^www\. [NC]
RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Remove .php extension ───────────────────────────────────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# ── Block sensitive files ───────────────────────────────────
<FilesMatch "\.(env|log|json|lock|md)$">
  Order allow,deny
  Deny from all
</FilesMatch>

# ── Block form-handler direct access ───────────────────────
RewriteCond %{HTTP_REFERER} !^https://(www\.)?softercolor\.com [NC]
RewriteRule ^form-handler\.php$ - [F,L]

# ── Gzip compression ────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml application/xml text/xml
  AddOutputFilterByType DEFLATE font/woff font/woff2
</IfModule>

# ── Browser caching ─────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache (content changes)
  ExpiresByType text/html                 "access plus 1 hour"

  # CSS / JS — long cache (versioned filenames recommended)
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType text/javascript           "access plus 1 year"

  # Images
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/gif                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"

  # Fonts
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/font-woff     "access plus 1 year"

  # XML / sitemap
  ExpiresByType application/xml           "access plus 1 day"
  ExpiresByType text/xml                  "access plus 1 day"
</IfModule>

# ── Cache-Control headers ───────────────────────────────────
<IfModule mod_headers.c>
  # Immutable static assets
  <FilesMatch "\.(css|js|png|jpg|jpeg|gif|webp|svg|woff|woff2|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Security headers
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ── Keep-Alive ──────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>
